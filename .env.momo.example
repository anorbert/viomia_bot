# MOMO Payment Gateway Configuration
# Get these credentials from your MOMO API account

# API Credentials
MOMO_API_KEY=your-momo-api-key-here
MOMO_API_USER=your-momo-user-here
MOMO_API_SECRET=your-momo-secret-here

# API Endpoints
MOMO_PRIMARY_ENDPOINT=https://sandbox.momoapi.mtn.com
MOMO_SECONDARY_ENDPOINT=https://proxy.momoapi.mtn.com

# IP Whitelist (comma-separated, add MOMO server IPs)
# Example: MOMO_IP_WHITELIST=192.168.1.1,192.168.1.2
MOMO_IP_WHITELIST=

# Webhook Configuration
MOMO_WEBHOOK_TIMEOUT=30
MOMO_WEBHOOK_RETRY=3

# Currency (default: RWF for Rwanda)
MOMO_CURRENCY=RWF

# Rate Limiting
MOMO_RATE_LIMIT_REQUESTS=100
MOMO_RATE_LIMIT_MINUTES=1
